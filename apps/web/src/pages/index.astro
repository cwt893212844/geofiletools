---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig, convertTools, utilityTools } from '../data/tools';
---

<BaseLayout
  title="Free GIS Vector Converters"
  description={siteConfig.description}
>
  <section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-brand-600">CAD to GIS · Browser-native</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        Convert vector GIS files without opening desktop software
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-600">{siteConfig.description}</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-slate-600">
        <span class="rounded-full bg-white px-3 py-1 shadow-sm ring-1 ring-slate-200">DXF / DWG / SHP</span>
        <span class="rounded-full bg-white px-3 py-1 shadow-sm ring-1 ring-slate-200">GeoJSON / KML / GPX</span>
        <span class="rounded-full bg-white px-3 py-1 shadow-sm ring-1 ring-slate-200">No upload</span>
      </div>
    </div>
    <div class="rounded-3xl border border-brand-100 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Why GeoFileTools?</h2>
      <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-600">
        <li>Skip the QGIS import wizard for quick one-off conversions.</li>
        <li>Preview GeoJSON on a map immediately after conversion.</li>
        <li>Keep project data on your machine — ideal for client CAD/GIS handoffs.</li>
      </ul>
    </div>
  </section>

  <section id="converters" class="mt-16">
    <h2 class="text-2xl font-semibold text-slate-900">Converters</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {convertTools.map((tool) => (
        <a href={tool.href} class="rounded-2xl border border-slate-200 bg-white p-5 transition hover:border-brand-500 hover:shadow-sm">
          <h3 class="font-semibold text-slate-900">{tool.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{tool.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section id="tools" class="mt-16">
    <h2 class="text-2xl font-semibold text-slate-900">Utilities</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {utilityTools.map((tool) => (
        <a href={tool.href} class="rounded-2xl border border-slate-200 bg-white p-5 transition hover:border-brand-500 hover:shadow-sm">
          <h3 class="font-semibold text-slate-900">{tool.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{tool.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
